{
  "installCommand": "npm install && npx prisma generate",
  "rewrites": [
    { "source": "/(.*)", "destination": "/api" }
  ],
  "functions": {
    "api/index.ts": {
      "maxDuration": 30,
      "memory": 1024,
      "includeFiles": "{prisma/**,node_modules/.prisma/**,node_modules/@prisma/client/**}"
    }
  }
}
