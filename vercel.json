{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "installCommand": "cd api && npm install && npx prisma generate",
  "builds": [
    {
      "src": "api/api/index.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "api/node_modules/.prisma/**",
          "api/node_modules/@prisma/client/**",
          "api/prisma/**"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/api/index.ts"
    }
  ]
}
